{
  "name": "haloguard-vscode",
  "displayName": "HaloGuard - Hallucination Detection",
  "description": "Real-time hallucination detection for GitHub Copilot Chat",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "ai",
    "hallucination",
    "detection",
    "copilot",
    "chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "haloguard.openPanel",
        "title": "HaloGuard: Open Safety Panel"
      },
      {
        "command": "haloguard.toggleDetection",
        "title": "HaloGuard: Toggle Detection"
      }
    ],
    "viewsContainers": {
      "sidebar": [
        {
          "id": "haloguard-panel",
          "title": "HaloGuard",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "haloguard-panel": [
        {
          "type": "webview",
          "id": "haloguard.sidebar",
          "name": "Safety Monitor"
        }
      ]
    },
    "configuration": {
      "title": "HaloGuard",
      "properties": {
        "haloguard.backendUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Backend API URL"
        },
        "haloguard.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect on new messages"
        }
      }
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "shared-client-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.21.0",
    "eslint": "^8.56.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
