# Environment Variables for HaloGuard Licensing System
# Copy this file to .env.development and .env.production
# Fill in values from your Stripe dashboard

# ============================================================================
# STRIPE CONFIGURATION (Required for premium features)
# ============================================================================

# Test Mode / Development
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnop
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdefghijklmnop
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnop

# Production (Use environment secrets, never commit!)
# STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
# STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
# STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# Optional: Stripe Account ID (for Stripe Connect)
# STRIPE_ACCOUNT_ID=acct_1234567890abcdef

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================

# Your webhook URL
# Development: Use ngrok (https://ngrok.com)
# ngrok http 3000
# Then use: https://xxxx.ngrok.io/webhooks/stripe
WEBHOOK_URL=http://localhost:3000/webhooks/stripe

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database path for licensing data
DB_PATH=./data/haloguard.db

# Enable migrations on startup
AUTO_MIGRATE=true

# ============================================================================
# PRICING CONFIGURATION (Optional - customize per region)
# ============================================================================

# USD pricing for Pro tier
PRO_PRICE_USD=9.99

# EUR pricing for Pro tier (if supporting multiple currencies)
# PRO_PRICE_EUR=9.99

# ============================================================================
# FEATURE CONFIGURATION
# ============================================================================

# Enable/disable licensing system
LICENSING_ENABLED=true

# Enable/disable email notifications for billing events
BILLING_EMAIL_ENABLED=true

# Free tier max API calls per month
FREE_TIER_API_CALLS=100

# Free tier max custom KB records
FREE_TIER_KB_RECORDS=5

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Enable detailed Stripe API logging (development only)
STRIPE_LOG_LEVEL=warn

# ============================================================================
# SCHEDULED TASKS (Cron Configuration)
# ============================================================================

# Enable automatic quota reset (1st of month)
ENABLE_QUOTA_RESET=true

# Enable automatic quota cleanup (keep 90 days of history)
ENABLE_QUOTA_CLEANUP=true

# Enable automatic billing archive
ENABLE_BILLING_ARCHIVE=true

# ============================================================================
# SECURITY
# ============================================================================

# Enable webhook signature verification (always true in production)
VERIFY_WEBHOOK_SIGNATURE=true

# Rate limit for API (requests per hour)
API_RATE_LIMIT=100

# Rate limit multiplier for Pro users
PRO_RATE_LIMIT_MULTIPLIER=10

# ============================================================================
# EMAIL CONFIGURATION (For billing notifications)
# ============================================================================

# Email provider (sendgrid, mailgun, ses, smtp)
EMAIL_PROVIDER=sendgrid

# SendGrid API key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Email address for billing notifications
BILLING_EMAIL_FROM=billing@haloguard.ai

# Email template IDs
BILLING_EMAIL_TEMPLATE_UPGRADE=d-xxxxxxxxxxxx
BILLING_EMAIL_TEMPLATE_PAYMENT_RECEIVED=d-xxxxxxxxxxxx
BILLING_EMAIL_TEMPLATE_PAYMENT_FAILED=d-xxxxxxxxxxxx

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================

# Enable usage analytics
ENABLE_ANALYTICS=true

# Analytics provider (mixpanel, amplitude, segment)
ANALYTICS_PROVIDER=mixpanel

# Mixpanel token
MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ============================================================================
# COMPLIANCE
# ============================================================================

# Enable PCI compliance logging
PCI_LOGGING_ENABLED=true

# Enable GDPR data deletion
GDPR_ENABLED=true

# Data retention period (days)
DATA_RETENTION_DAYS=365

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Stripe API version to use
STRIPE_API_VERSION=2023-10-16

# Custom product ID for Stripe products
STRIPE_PRODUCT_ID=prod_xxxxxxxxxxxx

# Enable verbose debugging (development only)
DEBUG=true

# ============================================================================
# NOTES
# ============================================================================

# 1. Get Stripe keys from: https://dashboard.stripe.com/test/apikeys
# 2. Get webhook secret from: https://dashboard.stripe.com/test/webhooks
# 3. For ngrok setup: brew install ngrok
#    ngrok http 3000
#    Use ngrok URL as WEBHOOK_URL
# 4. Never commit real keys to git - use CI/CD secrets
# 5. Rotate keys periodically (every 90 days recommended)
# 6. Enable 2FA on your Stripe account
# 7. Test webhook with: stripe trigger customer.subscription.created
# 8. Monitor webhook delivery in Stripe Dashboard

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================

# [ ] Create Stripe account at https://stripe.com
# [ ] Get API keys from Settings → API Keys
# [ ] Set up webhook at Developers → Webhooks
# [ ] Copy webhook signing secret
# [ ] Fill in STRIPE_SECRET_KEY below
# [ ] Fill in STRIPE_PUBLISHABLE_KEY below
# [ ] Fill in STRIPE_WEBHOOK_SECRET below
# [ ] For development, use ngrok for webhook URL
# [ ] Test with "stripe listen --forward-to localhost:3000/webhooks/stripe"
# [ ] Run "npm test -- licensing/" to verify setup
# [ ] Deploy with production keys to staging first
# [ ] Test with real Stripe test cards
# [ ] Switch to live keys in production

