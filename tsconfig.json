{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@shared/core": ["shared-core/src"],
      "@shared/ui": ["shared-ui/src"],
      "@shared/client": ["shared-client-sdk/src"]
    }
  },
  "include": [
    "shared-core/**/*.ts",
    "shared-core/**/*.tsx",
    "shared-ui/**/*.ts",
    "shared-ui/**/*.tsx",
    "shared-client-sdk/**/*.ts",
    "shared-client-sdk/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "chrome-extension", "vscode-extension", "python-workers"]
}
