{
  "manifest_version": 3,
  "name": "HaloGuard",
  "version": "0.2.0",
  "description": "Real-time AI hallucination detection for ChatGPT, Claude, Gemini, and more",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "webRequest"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://perplexity.ai/*",
    "https://grok.com/*",
    "https://x.com/grok/*",
    "https://meta.ai/*",
    "https://deepseek.com/*",
    "https://pi.ai/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/grok/*",
        "https://meta.ai/*",
        "https://deepseek.com/*",
        "https://pi.ai/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "HaloGuard",
    "default_popup": "popup.html"
  }
}
