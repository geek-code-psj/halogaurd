{
  "manifest_version": 3,
  "name": "HaloGuard - AI Hallucination Detector",
  "version": "0.2.0",
  "description": "Real-time AI hallucination detection for ChatGPT, Claude, Gemini, and more",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "webRequest", "contextMenus", "alarms"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://perplexity.ai/*",
    "https://grok.com/*",
    "https://x.com/grok/*",
    "https://meta.ai/*",
    "https://deepseek.com/*",
    "https://pi.ai/*",
    "https://haloguard-production.up.railway.app/*",
    "https://en.wikipedia.org/*"
  ],
  "background": {
    "service_worker": "background/serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/grok/*",
        "https://meta.ai/*",
        "https://deepseek.com/*",
        "https://pi.ai/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "HaloGuard - AI Hallucination Detector",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup/popup.css", "popup/popup.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
