{
  "name": "shared-core",
  "version": "0.1.0",
  "description": "HaloGuard detection engine backend",
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "dev:backend": "tsx watch src/server.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run src",
    "test:watch": "vitest watch src",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.2",
    "bull": "^4.11.4",
    "bullmq": "^5.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pino": "^8.17.2",
    "pino-http": "^8.5.0",
    "pino-pretty": "^10.2.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "stripe": "^14.18.0",
    "typescript": "^5.3.3",
    "zod": "^3.13.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0"
  }
}
